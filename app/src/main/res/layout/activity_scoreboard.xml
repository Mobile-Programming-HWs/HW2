<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true"
    tools:context=".ScoreboardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scoreboard"
            android:textColor="@color/quiz_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/scoreboard_subtitle"
            android:textColor="@color/quiz_text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@color/rank_gold"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:text="Rank #1"
                android:textColor="@android:color/black"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/email1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@android:color/black"
                tools:text="player@example.com" />

            <TextView
                android:id="@+id/score1"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                tools:text="90" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/rank_silver"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:text="Rank #2"
                android:textColor="@android:color/black"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/email2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@android:color/black"
                tools:text="player@example.com" />

            <TextView
                android:id="@+id/score2"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                tools:text="70" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/rank_bronze"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:text="Rank #3"
                android:textColor="@android:color/black"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/email3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@android:color/black"
                tools:text="player@example.com" />

            <TextView
                android:id="@+id/score3"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                tools:text="50" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/rank_plain"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:text="Rank #4"
                android:textColor="@color/quiz_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/email4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/quiz_text_primary"
                tools:text="player@example.com" />

            <TextView
                android:id="@+id/score4"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/quiz_text_primary"
                android:textStyle="bold"
                tools:text="40" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/rank_plain"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:text="Rank #5"
                android:textColor="@color/quiz_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/email5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/quiz_text_primary"
                tools:text="player@example.com" />

            <TextView
                android:id="@+id/score5"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/quiz_text_primary"
                android:textStyle="bold"
                tools:text="30" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
